# Server
PORT=3100
APP_TIMEZONE=Europe/Madrid

# Calendar source
CALENDAR_USE_ICS=true
CALENDAR_ICS_URL=https://outlook.office365.com/owa/calendar/.../calendar.ics

# Moodle resolver
RESOLVER_USE_LIVE_MOODLE=true
MOODLE_BASE_URL=https://ecampus.esade.edu/my/
PLAYWRIGHT_USER_DATA_DIR=/Users/your-user/Documents/New project 4/data/storage/playwright-profile
PLAYWRIGHT_HEADLESS=false
RESOLVER_RECENT_LIMIT=2

# AI providers
SUMMARY_PROVIDER_DEFAULT=auto
SUMMARY_FALLBACK_ENABLED=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
CHATPDF_API_KEY=
CHATPDF_SOURCE_ID=

# Chunking
MAX_CHUNK_CHARS=2400
