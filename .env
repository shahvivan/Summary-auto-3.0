# Server
PORT=3100
APP_TIMEZONE=Europe/Madrid

# Calendar source
CALENDAR_USE_ICS=true
# Local ICS file (re-export from Outlook and replace data/config/calendar.ics to refresh):
CALENDAR_ICS_URL=data/config/calendar.ics
